{
  "name": "portfolio",
  "version": "1.0.0",
  "private": true,
  "description": "portfolio base Artesano",
  "main": "index.js",
  "type": "module",
  "repository": "git@github.com:SethVilla/Portfolio.git",
  "author": "Seth Villavicencio",
  "license": "MIT",
  "dependencies": {
    "-": "^0.0.1",
    "D": "^1.0.0",
    "dotenv": "^9.0.0",
    "env-cmd": "^10.1.0",
    "express": "^4.17.1"
  },
  "scripts": {
    "dev": "env-cmd -e dev nodemon --exec babel-node index.js",
    "prod": "env-cmd -e prod nodemon --exec babel-node index.js",
    "client": "cd ../client && yarn dev",
    "app": "npm-run-all --parallel dev client",
    "test": "jest",
    "test-watch": "jest --watchAll",
    "lint": "eslint --ignore-path .gitignore --ext .js,.ts,.tsx .",
    "check-types": "tsc",
    "prettier": "prettier --ignore-path .gitignore \"**/*.+(js|json|ts|tsx)\"",
    "format": "yarn run prettier --write",
    "check-format": "yarn run prettier --list-different",
    "validate": "npm-run-all --parallel check-types check-format lint test",
    "prepare": "cd .. && husky install server/.husky"
  },
  "devDependencies": {
    "@babel/core": "^7.14.0",
    "@babel/node": "^7.13.13",
    "@babel/preset-env": "^7.14.1",
    "@typescript-eslint/eslint-plugin": "^4.22.0",
    "@typescript-eslint/parser": "^4.22.0",
    "eslint": "^7.26.0",
    "eslint-config-prettier": "^8.3.0",
    "eslint-plugin-import": "^2.22.1",
    "eslint-plugin-jest": "^24.3.6",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^3.4.0",
    "eslint-plugin-testing-library": "^4.1.2",
    "husky": "^6.0.0",
    "jest": "^26.6.3",
    "lint-staged": "^10.5.4",
    "nodemon": "^2.0.7",
    "prettier": "^2.2.1",
    "typescript": "^4.2.4",
    "yarn-run-all": "^3.1.1"
  }
}
